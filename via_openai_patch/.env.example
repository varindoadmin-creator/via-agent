# ─── AI Provider ──────────────────────────────────────────────────────────────
# Use "openai" to run VIA with OpenAI, or "anthropic" to run with Claude.
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic / Claude, keep this if you still want provider switching.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Zoho Books ───────────────────────────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=
ZOHO_BASE_URL=https://www.zohoapis.com/books/v3
